{
  "global": {},
  "Collection 1/Mode 1": {
    "white": {
      "$extensions": {
        "com.figma.scopes": [
          "ALL_SCOPES"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "color",
      "$value": "#ffffff"
    },
    "Fuschia": {
      "60": {
        "$type": "color",
        "$value": "#fcddec"
      },
      "80": {
        "$type": "color",
        "$value": "#f178b6"
      },
      "100": {
        "$type": "color",
        "$value": "#ef5da8"
      }
    },
    "Iris": {
      "60": {
        "$type": "color",
        "$value": "#a5a6f6"
      },
      "80": {
        "$type": "color",
        "$value": "#7879f1"
      },
      "100": {
        "$type": "color",
        "$value": "#5d5fef"
      }
    },
    "shadow": {
      "$type": "boxShadow",
      "$value": {
        "color": "#00000040",
        "type": "dropShadow",
        "x": 0,
        "y": 4,
        "blur": 4,
        "spread": 0
      }
    },
    "fontFamilies": {
      "work-sans": {
        "$type": "fontFamilies",
        "$value": "Work Sans"
      }
    },
    "lineHeights": {
      "0": {
        "$type": "lineHeights",
        "$value": "AUTO"
      },
      "1": {
        "$type": "lineHeights",
        "$value": "AUTO"
      },
      "2": {
        "$type": "lineHeights",
        "$value": "AUTO"
      }
    },
    "fontWeights": {
      "work-sans-0": {
        "$type": "fontWeights",
        "$value": "Bold"
      },
      "work-sans-1": {
        "$type": "fontWeights",
        "$value": "Regular"
      }
    },
    "fontSize": {
      "0": {
        "$type": "fontSizes",
        "$value": 13
      },
      "1": {
        "$type": "fontSizes",
        "$value": 20
      },
      "2": {
        "$type": "fontSizes",
        "$value": 34
      }
    },
    "letterSpacing": {
      "0": {
        "$type": "letterSpacing",
        "$value": "-2%"
      }
    },
    "paragraphSpacing": {
      "0": {
        "$type": "paragraphSpacing",
        "$value": 0
      }
    },
    "Header 1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{fontFamilies.work-sans}",
        "fontWeight": "{fontWeights.work-sans-0}",
        "lineHeight": "{lineHeights.0}",
        "fontSize": "{fontSize.2}",
        "letterSpacing": "{letterSpacing.0}",
        "paragraphSpacing": "{paragraphSpacing.0}",
        "paragraphIndent": "{paragraphIndent.0}",
        "textCase": "{textCase.none}",
        "textDecoration": "{textDecoration.none}"
      }
    },
    "Header 2": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{fontFamilies.work-sans}",
        "fontWeight": "{fontWeights.work-sans-0}",
        "lineHeight": "{lineHeights.0}",
        "fontSize": "{fontSize.1}",
        "letterSpacing": "{letterSpacing.0}",
        "paragraphSpacing": "{paragraphSpacing.0}",
        "paragraphIndent": "{paragraphIndent.0}",
        "textCase": "{textCase.none}",
        "textDecoration": "{textDecoration.none}"
      }
    },
    "Body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "{fontFamilies.work-sans}",
        "fontWeight": "{fontWeights.work-sans-1}",
        "lineHeight": "{lineHeights.0}",
        "fontSize": "{fontSize.0}",
        "letterSpacing": "{letterSpacing.0}",
        "paragraphSpacing": "{paragraphSpacing.0}",
        "paragraphIndent": "{paragraphIndent.0}",
        "textCase": "{textCase.none}",
        "textDecoration": "{textDecoration.none}"
      }
    },
    "textCase": {
      "none": {
        "$type": "textCase",
        "$value": "none"
      }
    },
    "textDecoration": {
      "none": {
        "$type": "textDecoration",
        "$value": "none"
      }
    },
    "paragraphIndent": {
      "0": {
        "$type": "dimension",
        "$value": "0px"
      }
    }
  },
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": [
      "global",
      "Collection 1/Mode 1"
    ]
  }
}